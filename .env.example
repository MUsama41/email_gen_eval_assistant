GROQ_API_KEY=your_groq_api_key_here

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=email_assistant

MODEL_A=llama-3.3-70b-versatile
MODEL_B=llama-3.1-8b-instant
JUDGE_MODEL=openai/gpt-oss-120b

GEN_TEMPERATURE=0.4
JUDGE_TEMPERATURE=0.0
MAX_TOKENS=1024

SCORE_SCALE=100

CONCISENESS_MIN_WORDS=60
CONCISENESS_MAX_WORDS=220

METRIC_WEIGHT_FACT_RECALL=0.4
METRIC_WEIGHT_TONE=0.3
METRIC_WEIGHT_FLUENCY=0.3

DATA_DIR=data
RESULTS_DIR=results
CACHE_DIR=.cache
